# Server
PORT=3001
MAX_GATEWAYS=5

# Model API Keys (get your own)
XIAOMI_API_KEY=your-xiaomi-api-key-here
VENICE_API_KEY=your-venice-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
TOKENROUTER_API_KEY=your-tokenrouter-api-key-here

# Hermes binary path (optional, defaults to /home/ubuntu/.local/bin/hermes)
HERMES_BIN=/home/ubuntu/.local/bin/hermes
